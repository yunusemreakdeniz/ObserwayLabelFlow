<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:ObserwayLabelFlow.App.Converters"
                    xmlns:infra="clr-namespace:ObserwayLabelFlow.App.Infrastructure">

    <Color x:Key="Bg0">#0B1220</Color>
    <Color x:Key="Bg1">#0F1A2E</Color>
    <Color x:Key="Card">#131E35</Color>
    <Color x:Key="Stroke">#24314F</Color>
    <Color x:Key="Text0">#E9EEF9</Color>
    <Color x:Key="Text1">#B6C2E2</Color>
    <Color x:Key="Accent">#6EA8FE</Color>
    <Color x:Key="AccentHover">#8BB9FF</Color>
    <Color x:Key="AccentSoft">#1A2844</Color>
    <Color x:Key="Danger">#FF6B6B</Color>
    <Color x:Key="ToastSuccess">#34D399</Color>
    <Color x:Key="ToastWarning">#FBBF24</Color>
    <Color x:Key="ToastError">#FF6B6B</Color>
    <Color x:Key="ToastInfo">#6EA8FE</Color>

    <SolidColorBrush x:Key="Bg0Brush" Color="{StaticResource Bg0}" />
    <SolidColorBrush x:Key="Bg1Brush" Color="{StaticResource Bg1}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card}" />
    <SolidColorBrush x:Key="StrokeBrush" Color="{StaticResource Stroke}" />
    <SolidColorBrush x:Key="Text0Brush" Color="{StaticResource Text0}" />
    <SolidColorBrush x:Key="Text1Brush" Color="{StaticResource Text1}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="ToastSuccessBrush" Color="{StaticResource ToastSuccess}" />
    <SolidColorBrush x:Key="ToastWarningBrush" Color="{StaticResource ToastWarning}" />
    <SolidColorBrush x:Key="ToastErrorBrush" Color="{StaticResource ToastError}" />
    <SolidColorBrush x:Key="ToastInfoBrush" Color="{StaticResource ToastInfo}" />
    <SolidColorBrush x:Key="SurfaceInsetBrush" Color="#0B1428" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#14233F" />

    <BitmapImage x:Key="ObserwayLogoImage" UriSource="/Assets/obserway-logo.png" />
    <BitmapImage x:Key="ObserwayLogoTitleImage" UriSource="/Assets/obserway-logo-title.png" />
    <BitmapImage x:Key="ObserwayIconImage" UriSource="/Assets/obserway-icon.png" />

    <CornerRadius x:Key="R8">8</CornerRadius>
    <CornerRadius x:Key="R10">10</CornerRadius>
    <CornerRadius x:Key="R12">12</CornerRadius>
    <CornerRadius x:Key="R16">16</CornerRadius>
    <Thickness x:Key="Space8">8</Thickness>
    <Thickness x:Key="Space12">12</Thickness>
    <Thickness x:Key="Space16">16</Thickness>
    <Thickness x:Key="Space24">24</Thickness>
    <Thickness x:Key="PadCard">20</Thickness>
    <Thickness x:Key="PadItem">14</Thickness>

    <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="EmptyStatePanel" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="Padding" Value="24,28" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ProgressRing" TargetType="{x:Type ProgressBar}">
        <Setter Property="IsIndeterminate" Value="True" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="#24314F" />
    </Style>

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    <conv:BooleanToTextConverter x:Key="BooleanToTextConverter" />

    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="TitleBarText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="AppBrandMark" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="CornerRadius" Value="{StaticResource R8}" />
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style x:Key="AppBrandIconImage" TargetType="{x:Type Image}">
        <Setter Property="Source" Value="{StaticResource ObserwayIconImage}" />
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
    </Style>

    <Style x:Key="AppTitleLogoImage" TargetType="{x:Type Image}">
        <Setter Property="Source" Value="{StaticResource ObserwayLogoTitleImage}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
    </Style>

    <Style x:Key="AppHeroLogoImage" TargetType="{x:Type Image}">
        <Setter Property="Source" Value="{StaticResource ObserwayLogoImage}" />
        <Setter Property="MaxWidth" Value="440" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
    </Style>

    <Style x:Key="AppProductNameText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="10,0,0,1" />
    </Style>

    <Style x:Key="PanelHeaderTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
    </Style>

    <Style x:Key="PanelHeaderSubtitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="Margin" Value="0,3,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AccentBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource R10}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="AccentBadgeText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#081225" />
    </Style>

    <Style x:Key="StatusPill" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R10}" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StatusPillText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxWidth" Value="92" />
    </Style>

    <Style x:Key="StatusPillCompact" TargetType="{x:Type Border}" BasedOn="{StaticResource StatusPill}">
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinWidth" Value="108" />
    </Style>

    <Style x:Key="StatusPillCompactText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource StatusPillText}">
        <Setter Property="MaxWidth" Value="84" />
    </Style>

    <Style x:Key="SoftAccentBadge" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource R10}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

    <Style x:Key="SoftAccentBadgeText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style x:Key="FilterDivider" TargetType="{x:Type Border}">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Margin" Value="0,10,0,10" />
    </Style>

    <Style x:Key="EmptyStateIcon" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PreviewViewport" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style x:Key="MetaChipLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="infra:FieldLabelAssist.AppendColon" Value="True" />
    </Style>

    <Style x:Key="StatusBadge" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="#0B1428" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="FilterPanel" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R16}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
    </Style>

    <Style x:Key="FilterSectionTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
    </Style>

    <Style x:Key="FilterFieldLabel" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="Margin" Value="2,0,0,6" />
        <Setter Property="infra:FieldLabelAssist.AppendColon" Value="True" />
    </Style>

    <Style x:Key="CheckBoxModern" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,0,0,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="20"
                                Height="20"
                                CornerRadius="6"
                                Background="#0B1428"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1.5"
                                SnapsToDevicePixels="True">
                            <Path x:Name="CheckMark"
                                  Data="M2,6 L6,10 L14,2"
                                  Stroke="#081225"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  Margin="2"
                                  Stretch="Uniform" />
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CheckBoxDataGrid" TargetType="{x:Type CheckBox}" BasedOn="{StaticResource CheckBoxModern}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Border x:Name="Box"
                            Width="22"
                            Height="22"
                            CornerRadius="6"
                            Background="#0B1428"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1.5"
                            SnapsToDevicePixels="True">
                        <Path x:Name="CheckMark"
                              Data="M3,7 L7,11 L15,3"
                              Stroke="#081225"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Visibility="Collapsed"
                              Margin="3"
                              Stretch="Uniform" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="#14233F" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarModern" TargetType="{x:Type Calendar}">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style TargetType="{x:Type CalendarItem}">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
    </Style>

    <Style TargetType="{x:Type CalendarDayButton}">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarDayButton}">
                    <Grid>
                        <Border x:Name="Bg"
                                CornerRadius="8"
                                Background="Transparent" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="#081225" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bg" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type CalendarButton}">
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="MinWidth" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CalendarButton}">
                    <Border x:Name="Bg"
                            CornerRadius="8"
                            Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DatePickerFieldHost" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="Background" Value="#0B1428" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="4,0,2,0" />
    </Style>

    <Style x:Key="DatePickerField" TargetType="{x:Type DatePicker}">
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="SelectedDateFormat" Value="Short" />
        <Setter Property="CalendarStyle" Value="{StaticResource CalendarModern}" />
    </Style>

    <!-- Legacy alias kept for any remaining references -->
    <Style x:Key="DatePickerModern" TargetType="{x:Type DatePicker}" BasedOn="{StaticResource DatePickerField}" />

    <Style TargetType="{x:Type DatePickerTextBox}">
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,0,4,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="ProductMetaChip" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R8}" />
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="0,0,6,6" />
    </Style>

    <Style x:Key="ProductCardSurface" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <!-- Card surface: flat, bordered — no heavy shadow -->
    <Style x:Key="CardSurface" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R16}" />
        <Setter Property="Padding" Value="{StaticResource PadCard}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
    </Style>

    <Style x:Key="ToolbarBar" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
    </Style>

    <Style x:Key="ProductCard" TargetType="{x:Type Border}">
        <Setter Property="CornerRadius" Value="{StaticResource R12}" />
        <Setter Property="Padding" Value="{StaticResource PadItem}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="infra:FieldLabelAssist.AppendColon" Value="True" />
    </Style>

    <Style x:Key="ValueText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="SelectableReadOnlyTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="IsReadOnlyCaretVisible" Value="True" />
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="SelectionOpacity" Value="0.55" />
        <Setter Property="Cursor" Value="IBeam" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  Focusable="False"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SelectableValueTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource SelectableReadOnlyTextBox}">
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="SelectableMultilineTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource SelectableReadOnlyTextBox}">
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
