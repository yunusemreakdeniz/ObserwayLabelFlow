<Application x:Class="ObserwayLabelFlow.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ObserwayLabelFlow.App.Converters"
             xmlns:local="clr-namespace:ObserwayLabelFlow.App"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Application scope: XAML designer resolves these reliably when Theme.xaml is edited in isolation -->
            <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" />
            <conv:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibilityConverter" />
            <conv:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibilityConverter" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <conv:UrlToImageSourceConverter x:Key="UrlToImageSourceConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
