<Window x:Class="ObserwayLabelFlow.App.Views.ProductImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource Loc_ProductImagePreviewTitle}"
        Height="560"
        Width="720"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF0B1220"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        Icon="/Assets/obserway.ico"
        FontSize="14">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            CaptionHeight="48" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#12000000" CornerRadius="18,18,0,0" />
            <Border VerticalAlignment="Bottom"
                    Height="1"
                    Background="{StaticResource StrokeBrush}"
                    Opacity="0.45" />
            <TextBlock x:Name="TitleText"
                       Margin="18,0,52,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource PanelHeaderTitle}"
                       TextTrimming="CharacterEllipsis" />
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Style="{StaticResource ChromeButton}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Close_Click"
                    Content="✕" />
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource CardSurface}"
                Margin="18,0,18,18"
                Padding="0">
            <Grid>
                <ScrollViewer x:Name="PreviewScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              PreviewMouseWheel="PreviewScroll_PreviewMouseWheel"
                              SizeChanged="PreviewScroll_SizeChanged">
                    <Image x:Name="PreviewImage"
                           Stretch="None">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="PreviewScale" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>
                </ScrollViewer>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Padding="4,2"
                        CornerRadius="8"
                        Background="{DynamicResource ZoomToolbarOverlayBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource ChromeIconButton}"
                                Click="ZoomOut_Click"
                                ToolTip="{DynamicResource Loc_LabelPreviewZoomOut}"
                                Content="&#xE71F;" />
                        <TextBlock x:Name="ZoomPercentText"
                                   MinWidth="44"
                                   Margin="4,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource Text0Brush}"
                                   Text="100%" />
                        <Button Style="{StaticResource ChromeIconButton}"
                                Click="ZoomIn_Click"
                                ToolTip="{DynamicResource Loc_LabelPreviewZoomIn}"
                                Content="&#xE8A3;" />
                        <Border Width="1"
                                Margin="4,4"
                                Background="{StaticResource StrokeBrush}" />
                        <Button Style="{StaticResource ChromeIconButton}"
                                Click="ZoomFit_Click"
                                ToolTip="{DynamicResource Loc_LabelPreviewZoomFit}"
                                Content="&#xE7C3;" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
