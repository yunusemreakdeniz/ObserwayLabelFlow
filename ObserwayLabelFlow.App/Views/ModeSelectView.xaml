<UserControl x:Class="ObserwayLabelFlow.App.Views.ModeSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="480"
             d:DesignWidth="900"
             Background="{StaticResource Bg0Brush}">
    <Grid Margin="40,24">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="780">
            <TextBlock Text="{DynamicResource Loc_ModeSelect_Title}"
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Text0Brush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock Margin="0,10,0,36"
                       Text="{DynamicResource Loc_ModeSelect_Subtitle}"
                       FontSize="15"
                       Foreground="{StaticResource Text1Brush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <UniformGrid Columns="2" Rows="1">
                <Button Style="{StaticResource ModeSelectCardButton}"
                        Margin="0,0,12,0"
                        Command="{Binding SelectProductInboundCommand}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource ModeSelectIconHost}">
                            <TextBlock Text="&#xE8F1;"
                                       Style="{StaticResource ModeSelectIconGlyph}" />
                        </Border>
                        <TextBlock Margin="0,18,0,0"
                                   Text="{DynamicResource Loc_ModeSelect_ProductInboundTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{DynamicResource Loc_ModeSelect_ProductInboundDesc}"
                                   FontSize="13"
                                   Foreground="{StaticResource Text1Brush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxWidth="240" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ModeSelectCardButton}"
                        Margin="12,0,0,0"
                        Command="{Binding SelectProductOutboundCommand}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource ModeSelectIconHost}">
                            <TextBlock Text="&#xE898;"
                                       Style="{StaticResource ModeSelectIconGlyph}" />
                        </Border>
                        <TextBlock Margin="0,18,0,0"
                                   Text="{DynamicResource Loc_ModeSelect_ProductOutboundTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{DynamicResource Loc_ModeSelect_ProductOutboundDesc}"
                                   FontSize="13"
                                   Foreground="{StaticResource Text1Brush}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxWidth="240" />
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
