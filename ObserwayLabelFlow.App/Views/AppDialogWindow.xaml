<Window x:Class="ObserwayLabelFlow.App.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF0B1220"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        MaxWidth="480"
        ShowInTaskbar="False"
        Icon="/Assets/obserway.ico"
        FontSize="15">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CornerRadius="16"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            CaptionHeight="0" />
    </shell:WindowChrome.WindowChrome>

    <Border Style="{StaticResource CardSurface}"
            Margin="10"
            Padding="22">
        <Grid MinWidth="320">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border x:Name="IconBadge"
                        Width="42"
                        Height="42"
                        CornerRadius="21"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="IconText"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TitleText"
                           Margin="14,2,0,0"
                           TextWrapping="Wrap"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Text0Brush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBox x:Name="MessageText"
                     Grid.Row="2"
                     Style="{StaticResource SelectableMultilineTextBox}"
                     MinWidth="280"
                     MaxWidth="420"
                     FontSize="15"
                     Foreground="{StaticResource Text1Brush}" />

            <Button x:Name="OkButton"
                    Grid.Row="4"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    Height="44"
                    Style="{StaticResource ButtonPrimary}"
                    Click="Ok_Click"
                    Content="{DynamicResource Loc_DialogOk}" />

            <Grid x:Name="ConfirmButtonsPanel"
                  Grid.Row="4"
                  Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        Style="{StaticResource ButtonGhost}"
                        Click="Cancel_Click"
                        Content="{DynamicResource Loc_DialogCancel}" />

                <Button Grid.Column="2"
                        MinWidth="110"
                        Height="44"
                        Style="{StaticResource ButtonPrimary}"
                        Click="Confirm_Click"
                        Content="{DynamicResource Loc_DialogYes}" />
            </Grid>
        </Grid>
    </Border>
</Window>
