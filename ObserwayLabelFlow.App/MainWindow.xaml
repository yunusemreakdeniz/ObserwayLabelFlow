<Window x:Class="ObserwayLabelFlow.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:ObserwayLabelFlow.App.Controls"
        xmlns:infra="clr-namespace:ObserwayLabelFlow.App.Infrastructure"
        mc:Ignorable="d"
        Title="{DynamicResource Loc_WindowTitle}"
        Height="720"
        Width="1440"
        MinWidth="960"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#FF0B1220"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        ShowInTaskbar="True"
        Icon="/Assets/obserway.ico"
        FontSize="14"
        Loaded="Window_Loaded">

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="P" Command="{Binding PrintLabelCommand}" />
    </Window.InputBindings>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            CaptionHeight="52" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Background="#12000000" CornerRadius="18,18,0,0" />
            <Border VerticalAlignment="Bottom"
                    Height="1"
                    Background="{StaticResource StrokeBrush}"
                    Opacity="0.45" />

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="18,0,0,0">
                <Image Style="{StaticResource AppTitleLogoImage}" />
                <TextBlock Style="{StaticResource AppProductNameText}"
                           Text="{DynamicResource Loc_BrandLabelFlow}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource Text1Brush}"
                           FontSize="14"
                           infra:FieldLabelAssist.LocKey="LanguageLabel"
                           infra:FieldLabelAssist.AppendColon="True" />
                <Border Style="{StaticResource LanguageComboHost}">
                    <ComboBox Margin="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{StaticResource Text0Brush}"
                              FontSize="14"
                              Padding="10,2"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding LanguageOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </Border>
            </StackPanel>

            <Button Grid.Column="2"
                    x:Name="UserMenuButton"
                    Style="{StaticResource ChromeIconButton}"
                    Margin="0,0,8,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{Binding ToggleUserMenuCommand}"
                    ToolTip="{DynamicResource Loc_UserMenuTitle}"
                    Content="&#xE77B;" />

            <Popup Placement="Bottom"
                   PlacementTarget="{Binding ElementName=UserMenuButton}"
                   IsOpen="{Binding IsUserMenuOpen, Mode=TwoWay}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Style="{StaticResource CardSurface}"
                        Padding="14,12"
                        MinWidth="210"
                        Margin="0,6,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding UserDisplayName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Stretch"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Margin="0,12,0,0"
                                Style="{StaticResource ButtonGhost}"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                FontSize="14"
                                Command="{Binding LogoutCommand}"
                                Content="{DynamicResource Loc_Logout}" />
                    </StackPanel>
                </Border>
            </Popup>

            <Button Grid.Column="3"
                    Style="{StaticResource ChromeIconButton}"
                    Margin="0,0,8,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Settings_Click"
                    ToolTip="{DynamicResource Loc_SettingsTitle}"
                    Content="&#xE713;" />

            <StackPanel Grid.Column="4"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,14,0">
                <Button Style="{StaticResource ChromeButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="Minimize_Click"
                        Content="—" />
                <Button Margin="8,0,0,0"
                        Style="{StaticResource ChromeButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="Close_Click"
                        Content="✕" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="16,4,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Command bar: tracking + query + device status -->
            <Border Grid.Row="0" Style="{StaticResource ToolbarBar}" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" MinWidth="160" MaxWidth="240" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" MinWidth="118" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource FilterFieldLabel}"
                                   infra:FieldLabelAssist.LocKey="TrackingSectionTitle" />
                        <Grid>
                            <TextBox x:Name="TrackingBox"
                                     Style="{StaticResource TextBoxModern}"
                                     Height="42"
                                     FontSize="14"
                                     Padding="12,9"
                                     Text="{Binding TrackingNumber, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="TrackingBox_TextChanged"
                                     PreviewKeyDown="TrackingBox_PreviewKeyDown" />
                            <TextBlock IsHitTestVisible="False"
                                       Margin="14,0,10,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource Text1Brush}"
                                       Opacity="0.55"
                                       Text="{DynamicResource Loc_TrackingPlaceholder}"
                                       Visibility="{Binding TrackingNumber, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>

                    <Button Grid.Column="2"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource ButtonPrimary}"
                            Height="42"
                            MinWidth="160"
                            FontSize="14"
                            Content="{DynamicResource Loc_QueryAndPrint}"
                            Command="{Binding QueryAndPrintCommand}" />

                    <StackPanel Grid.Column="4"
                                VerticalAlignment="Bottom">
                        <Border Style="{StaticResource StatusPillCompact}"
                                Margin="0,0,0,6"
                                ToolTip="{Binding PrinterStatusText}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="{Binding PrinterStatusBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource StatusPillCompactText}"
                                           Text="{Binding PrinterStatusText}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPillCompact}"
                                ToolTip="{Binding ScannerStatusText}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="{Binding ScannerStatusBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Style="{StaticResource StatusPillCompactText}"
                                           Text="{Binding ScannerStatusText}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="2"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Style="{StaticResource TabControlFullWidth}">
                <TabItem Header="{DynamicResource Loc_TabOperation}" Style="{StaticResource TabItemFullWidth}">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="280" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1*" MinWidth="240" MaxWidth="520" />
                        </Grid.ColumnDefinitions>

                        <!-- Label preview (slightly smaller) -->
                        <Border Grid.Column="0" Style="{StaticResource CardSurface}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" MinHeight="180" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PanelHeaderTitle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{DynamicResource Loc_LabelReadyTitle}"
                                                   Visibility="{Binding LabelReady, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Style="{StaticResource PanelHeaderTitle}"
                                                   Text="{DynamicResource Loc_PrintScanTitle}"
                                                   Visibility="{Binding LabelReady, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <TextBlock Style="{StaticResource PanelHeaderSubtitle}"
                                                   Text="{DynamicResource Loc_LabelReadySubtitle}"
                                                   Visibility="{Binding LabelReady, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Style="{StaticResource PanelHeaderSubtitle}"
                                                   Text="{DynamicResource Loc_PrintHint}"
                                                   Visibility="{Binding LabelReady, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ButtonPrimary}"
                                            MinWidth="130"
                                            Height="40"
                                            Padding="16,8"
                                            FontSize="13"
                                            Command="{Binding PrintLabelCommand}"
                                            Content="{DynamicResource Loc_Print}" />
                                </Grid>

                                <Border Grid.Row="2" Style="{StaticResource PreviewViewport}">
                                    <Grid>
                                        <ScrollViewer x:Name="PdfPreviewScroll"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalContentAlignment="Center"
                                                      VerticalContentAlignment="Center"
                                                      PreviewMouseWheel="PdfPreviewScroll_PreviewMouseWheel"
                                                      SizeChanged="PdfPreviewScroll_SizeChanged"
                                                      Visibility="{Binding LabelReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image x:Name="PdfPreviewImage"
                                                   Stretch="None">
                                                <Image.LayoutTransform>
                                                    <ScaleTransform x:Name="PdfPreviewScale" ScaleX="1" ScaleY="1" />
                                                </Image.LayoutTransform>
                                            </Image>
                                        </ScrollViewer>
                                        <Border Background="{DynamicResource Bg0Brush}"
                                                Visibility="{Binding LabelReady, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        MaxWidth="320">
                                                <Border Style="{StaticResource EmptyStateIcon}">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE8D5;"
                                                               FontSize="22"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Margin="0,12,0,0"
                                                           Style="{StaticResource PanelHeaderTitle}"
                                                           TextAlignment="Center"
                                                           Text="{DynamicResource Loc_PrintScanTitle}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Style="{StaticResource PanelHeaderSubtitle}"
                                                           TextAlignment="Center"
                                                           Text="{DynamicResource Loc_PrintHint}" />
                                            </StackPanel>
                                        </Border>
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="8"
                                                Padding="4,2"
                                                CornerRadius="8"
                                                Background="{DynamicResource ZoomToolbarOverlayBrush}"
                                                BorderBrush="{StaticResource StrokeBrush}"
                                                BorderThickness="1"
                                                Visibility="{Binding LabelReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource ChromeIconButton}"
                                                        Click="PdfZoomOut_Click"
                                                        ToolTip="{DynamicResource Loc_LabelPreviewZoomOut}"
                                                        Content="&#xE71F;" />
                                                <TextBlock x:Name="PdfZoomPercentText"
                                                           MinWidth="44"
                                                           Margin="4,0"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{StaticResource Text0Brush}"
                                                           Text="100%" />
                                                <Button Style="{StaticResource ChromeIconButton}"
                                                        Click="PdfZoomIn_Click"
                                                        ToolTip="{DynamicResource Loc_LabelPreviewZoomIn}"
                                                        Content="&#xE8A3;" />
                                                <Border Width="1"
                                                        Margin="4,4"
                                                        Background="{StaticResource StrokeBrush}" />
                                                <Button Style="{StaticResource ChromeIconButton}"
                                                        Click="PdfZoomFit_Click"
                                                        ToolTip="{DynamicResource Loc_LabelPreviewZoomFit}"
                                                        Content="&#xE7C3;" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="4"
                                        Style="{StaticResource ToolbarBar}"
                                        Padding="10,8"
                                        Visibility="{Binding LabelReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource CaptionText}" Margin="0"
                                                       infra:FieldLabelAssist.LocKey="HistoryTracking" />
                                            <TextBox Grid.Column="1"
                                                     Style="{StaticResource SelectableValueTextBox}"
                                                     FontSize="14"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding DisplayedTrackingNumber, Mode=OneWay}" />
                                            <TextBlock Grid.Column="2"
                                                       Style="{StaticResource CaptionText}"
                                                       Margin="12,0,0,0"
                                                       infra:FieldLabelAssist.LocKey="ObserwayOrderNumber" />
                                            <TextBox Grid.Column="3"
                                                     Style="{StaticResource SelectableValueTextBox}"
                                                     FontSize="14"
                                                     Text="{Binding CurrentOrderNumber, Mode=OneWay}" />
                                        </Grid>
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource CaptionText}" Margin="0"
                                                       infra:FieldLabelAssist.LocKey="AmazonOrderId" />
                                            <TextBox Grid.Column="1"
                                                     Style="{StaticResource SelectableValueTextBox}"
                                                     FontSize="14"
                                                     Text="{Binding CurrentAmazonOrderId, Mode=OneWay}" />
                                            <TextBlock Grid.Column="2"
                                                       Style="{StaticResource CaptionText}"
                                                       Margin="12,0,0,0"
                                                       infra:FieldLabelAssist.LocKey="HistoryCarrier" />
                                            <TextBox Grid.Column="3"
                                                     Style="{StaticResource SelectableValueTextBox}"
                                                     FontSize="14"
                                                     Text="{Binding CurrentCarrierName, Mode=OneWay}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1"
                                      Style="{StaticResource GridSplitterModern}"
                                      ResizeBehavior="PreviousAndNext" />

                        <!-- Products sidebar -->
                        <Border Grid.Column="2" Style="{StaticResource CardSurface}" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PanelHeaderTitle}"
                                                   Text="{DynamicResource Loc_ProductsSectionTitle}" />
                                        <TextBlock Style="{StaticResource PanelHeaderSubtitle}"
                                                   Text="{DynamicResource Loc_ProductsSectionHint}" />
                                    </StackPanel>
                                    <Border Style="{StaticResource AccentBadge}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasActiveOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource AccentBadgeText}"
                                                       Text="{Binding ProductItemCount}" />
                                            <TextBlock Style="{StaticResource AccentBadgeText}"
                                                       Margin="5,0,0,0"
                                                       Text="{DynamicResource Loc_ProductsCountSuffix}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ScrollViewer Grid.Row="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Visibility="{Binding HasActiveOrder, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding ProductItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ProductCardSurface}">
                                                    <StackPanel>
                                                        <Border MinHeight="120"
                                                                MaxHeight="220"
                                                                Background="{StaticResource SurfaceInsetBrush}">
                                                            <Grid>
                                                                <Border Margin="12"
                                                                        CornerRadius="{StaticResource R10}"
                                                                        Background="{StaticResource AccentSoftBrush}"
                                                                        BorderBrush="{StaticResource StrokeBrush}"
                                                                        BorderThickness="1">
                                                                    <Image HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           MaxHeight="132"
                                                                           MaxWidth="300"
                                                                           Stretch="Uniform"
                                                                           Source="{Binding ImageUrl, Converter={StaticResource UrlToImageSourceConverter}}" />
                                                                </Border>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           Text="&#xE7B8;"
                                                                           FontSize="32"
                                                                           Foreground="{StaticResource Text1Brush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Opacity="0.22"
                                                                           Visibility="{Binding ImageUrl, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                                                            </Grid>
                                                        </Border>

                                                        <StackPanel Margin="14,12,14,14">
                                                            <TextBox Style="{StaticResource SelectableMultilineTextBox}"
                                                                     FontSize="14"
                                                                     FontWeight="SemiBold"
                                                                     MaxHeight="42"
                                                                     Text="{Binding OfficialName, Mode=OneWay}" />

                                                            <WrapPanel Margin="0,10,0,0">
                                                                <Border Style="{StaticResource ProductMetaChip}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Style="{StaticResource MetaChipLabel}"
                                                                                   infra:FieldLabelAssist.LocKey="ProductAsin" />
                                                                        <TextBox Style="{StaticResource SelectableReadOnlyTextBox}"
                                                                                 FontSize="12"
                                                                                 FontWeight="SemiBold"
                                                                                 MinWidth="40"
                                                                                 Text="{Binding Asin, Mode=OneWay}" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource ProductMetaChip}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Style="{StaticResource MetaChipLabel}"
                                                                                   infra:FieldLabelAssist.LocKey="ProductQuantity" />
                                                                        <TextBox Style="{StaticResource SelectableReadOnlyTextBox}"
                                                                                 FontSize="12"
                                                                                 FontWeight="SemiBold"
                                                                                 Foreground="{StaticResource AccentBrush}"
                                                                                 MinWidth="16"
                                                                                 Text="{Binding Quantity, Mode=OneWay}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </WrapPanel>

                                                            <TextBlock Margin="0,8,0,2"
                                                                       Style="{StaticResource CaptionText}"
                                                                       infra:FieldLabelAssist.LocKey="ProductSize" />
                                                            <TextBox Style="{StaticResource SelectableMultilineTextBox}"
                                                                     FontSize="12"
                                                                     Text="{Binding Size, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="2"
                                        Style="{StaticResource EmptyStatePanel}"
                                        Padding="20,28"
                                        Visibility="{Binding HasActiveOrder, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource EmptyStateIcon}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE7B8;"
                                                       FontSize="24"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Margin="0,12,0,0"
                                                   Style="{StaticResource PanelHeaderTitle}"
                                                   TextAlignment="Center"
                                                   Text="{DynamicResource Loc_ProductsEmptyTitle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource PanelHeaderSubtitle}"
                                                   TextAlignment="Center"
                                                   MaxWidth="260"
                                                   Text="{DynamicResource Loc_ProductsEmptyHint}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource Loc_TabHistory}" Style="{StaticResource TabItemFullWidth}">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource FilterPanel}" Padding="10,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="160" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Loc_HistoryFilterTitle}"
                                                   Style="{StaticResource FilterSectionTitle}"
                                                   Margin="0,0,10,4" />
                                        <Border Style="{StaticResource AccentBadge}"
                                                Margin="0,0,8,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource AccentBadgeText}"
                                                           Text="{Binding History.Count}" />
                                                <TextBlock Style="{StaticResource AccentBadgeText}"
                                                           Margin="4,0,0,0"
                                                           Text="{DynamicResource Loc_HistoryRecordsSuffix}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource SoftAccentBadge}"
                                                Margin="0,0,8,4"
                                                Visibility="{Binding SelectedHistoryCount, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource SoftAccentBadgeText}"
                                                           Text="{Binding SelectedHistoryCount}" />
                                                <TextBlock Style="{StaticResource SoftAccentBadgeText}"
                                                           Margin="4,0,0,0"
                                                           Text="{DynamicResource Loc_HistorySelectedSuffix}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <WrapPanel Grid.Column="1"
                                               Orientation="Horizontal"
                                               HorizontalAlignment="Right">
                                        <Button Style="{StaticResource ButtonGhost}"
                                                MinWidth="96"
                                                Height="34"
                                                FontSize="12"
                                                Margin="0,0,6,4"
                                                Content="{DynamicResource Loc_HistoryDeleteSelected}"
                                                Command="{Binding DeleteSelectedHistoryCommand}" />
                                        <Button Style="{StaticResource ButtonPrimary}"
                                                MinWidth="112"
                                                Height="34"
                                                FontSize="12"
                                                Margin="0,0,0,4"
                                                Content="{DynamicResource Loc_HistoryExportExcel}"
                                                Command="{Binding ExportHistoryToExcelCommand}" />
                                    </WrapPanel>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="160" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" MinWidth="84" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" MinWidth="72" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" MinWidth="128" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <TextBox Style="{StaticResource TextBoxModern}"
                                                 Height="36"
                                                 FontSize="13"
                                                 Padding="10,7"
                                                 Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding ApplyHistoryFilterCommand}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <TextBlock IsHitTestVisible="False"
                                                   Margin="12,0,8,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Text1Brush}"
                                                   Opacity="0.55"
                                                   Text="{DynamicResource Loc_HistorySearchLabel}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HistorySearchText, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                                    </Grid>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource ButtonPrimary}"
                                            Height="36"
                                            FontSize="12"
                                            Content="{DynamicResource Loc_HistoryFilter}"
                                            Command="{Binding ApplyHistoryFilterCommand}" />

                                    <Button Grid.Column="4"
                                            Style="{StaticResource ButtonGhost}"
                                            Height="36"
                                            FontSize="12"
                                            Content="{DynamicResource Loc_HistoryClearFilter}"
                                            Command="{Binding ClearHistoryFilterCommand}" />

                                    <Button Grid.Column="6"
                                            Style="{StaticResource ButtonGhost}"
                                            Height="36"
                                            FontSize="12"
                                            Padding="10,6"
                                            Command="{Binding ToggleHistoryAdvancedFilterCommand}">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Text" Value="{DynamicResource Loc_HistoryShowAdvancedFilters}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHistoryAdvancedFilterOpen}" Value="True">
                                                            <Setter Property="Text" Value="{DynamicResource Loc_HistoryHideAdvancedFilters}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="3"
                                        Margin="0,8,0,0"
                                        Padding="10,8"
                                        CornerRadius="{StaticResource R12}"
                                        Background="{StaticResource SurfaceInsetBrush}"
                                        BorderBrush="{StaticResource StrokeBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding IsHistoryAdvancedFilterOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="130" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" MinWidth="130" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource FilterFieldLabel}"
                                                       FontSize="11"
                                                       Margin="0,0,0,4"
                                                       infra:FieldLabelAssist.LocKey="HistoryFromLabel" />
                                            <Border Style="{StaticResource DatePickerFieldHost}">
                                                <DatePicker Style="{StaticResource DatePickerField}"
                                                            SelectedDate="{Binding HistoryFromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FilterFieldLabel}"
                                                       FontSize="11"
                                                       Margin="0,0,0,4"
                                                       infra:FieldLabelAssist.LocKey="HistoryToLabel" />
                                            <Border Style="{StaticResource DatePickerFieldHost}">
                                                <DatePicker Style="{StaticResource DatePickerField}"
                                                            SelectedDate="{Binding HistoryToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </StackPanel>

                                        <CheckBox Grid.Column="4"
                                                  VerticalAlignment="Bottom"
                                                  Margin="0,0,0,4"
                                                  Style="{StaticResource CheckBoxModern}"
                                                  FontSize="12"
                                                  Content="{DynamicResource Loc_HistoryOnlyErrors}"
                                                  IsChecked="{Binding HistoryOnlyErrors}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Style="{StaticResource CardSurface}"
                                Padding="10,8">
                            <Grid>
                            <DataGrid x:Name="HistoryGrid"
                                      ItemsSource="{Binding History}"
                                      Style="{StaticResource DataGridHistory}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      AlternationCount="2"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      CanUserResizeColumns="True"
                                      CanUserReorderColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource StrokeBrush}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn MinWidth="52"
                                                            Width="52"
                                                            CanUserSort="False"
                                                            CanUserResize="False">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource CheckBoxDataGrid}"
                                                          IsThreeState="True"
                                                          IsChecked="{Binding DataContext.AllHistorySelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ToolTip="{DynamicResource Loc_HistorySelectAll}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource CheckBoxDataGrid}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryDateUtc" Binding="{Binding CreatedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" MinWidth="118" Width="136" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryOrderNumber" Binding="{Binding OrderNumber}" MinWidth="92" Width="112" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryTracking" Binding="{Binding TrackingNumber}" MinWidth="104" Width="132" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryCustomer" Binding="{Binding CustomerName}" MinWidth="104" Width="148" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryStatus" Binding="{Binding OrderStatus}" MinWidth="84" Width="96" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryCarrier" Binding="{Binding CarrierName}" MinWidth="84" Width="104" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryProducts" Binding="{Binding ProductCount}" MinWidth="52" Width="62" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryCopies" Binding="{Binding Copies}" MinWidth="52" Width="58" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryPrinter" Binding="{Binding PrinterName}" MinWidth="92" Width="124" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryPaperSize" Binding="{Binding PaperSize}" MinWidth="80" Width="100" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridCheckBoxColumn HeaderLocKey="HistorySuccess" Binding="{Binding Success}" MinWidth="58" Width="64" CanUserResize="True" IsReadOnly="True" />
                                    <controls:LocalizedDataGridTextColumn HeaderLocKey="HistoryError" Binding="{Binding ErrorMessage}" MinWidth="120" Width="*" CanUserResize="True" IsReadOnly="True" />
                                    <DataGridTemplateColumn MinWidth="44" Width="48" CanUserResize="True">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE768;"
                                                           FontSize="11"
                                                           Foreground="{StaticResource Text1Brush}"
                                                           ToolTip="{DynamicResource Loc_HistoryOpenInOperation}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource DataGridActionButton}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        ToolTip="{DynamicResource Loc_HistoryOpenInOperation}"
                                                        Command="{Binding DataContext.SelectHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE768;" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn MinWidth="58" Width="66" CanUserResize="True">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{DynamicResource Loc_HistoryPrint}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text1Brush}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource DataGridActionButton}"
                                                        ToolTip="{DynamicResource Loc_HistoryPrint}"
                                                        Command="{Binding DataContext.ReprintCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{DynamicResource Loc_Print}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn MinWidth="48" Width="54" CanUserResize="True">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{DynamicResource Loc_HistoryDelete}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text1Brush}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource DataGridActionButtonDanger}"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        ToolTip="{DynamicResource Loc_HistoryDelete}"
                                                        Command="{Binding DataContext.DeleteHistoryEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="&#xE711;" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Style="{StaticResource EmptyStatePanel}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    MaxWidth="360"
                                    Padding="24,28"
                                    Margin="24"
                                    Visibility="{Binding IsHistoryEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Style="{StaticResource EmptyStateIcon}">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE81C;"
                                                   FontSize="22"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Margin="0,12,0,0"
                                               Style="{StaticResource PanelHeaderTitle}"
                                               TextAlignment="Center"
                                               Text="{DynamicResource Loc_HistoryEmptyTitle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource PanelHeaderSubtitle}"
                                               TextAlignment="Center"
                                               Text="{DynamicResource Loc_HistoryEmptyHint}" />
                                </StackPanel>
                            </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Global loading overlay -->
            <Border Grid.RowSpan="3"
                    Background="#B30B1220"
                    Panel.ZIndex="200"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <controls:LoadingSpinner Width="44"
                                             Height="44"
                                             SpinnerBrush="{StaticResource AccentBrush}" />
                    <TextBlock Margin="0,16,0,0"
                               Text="{DynamicResource Loc_QueryingLabel}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Text0Brush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <controls:ToastHost Grid.RowSpan="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,60,20,0"
                            Panel.ZIndex="900" />
    </Grid>
</Window>
